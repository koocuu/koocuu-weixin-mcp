MCP_BEARER_TOKEN=
MCP_ALLOWED_ORIGINS=

# Claude / Cursor MCP entry should use Vercel. Example:
# PUBLIC_BASE_URL=https://koocuu-weixin.vercel.app
PUBLIC_BASE_URL=https://weixin.koocuu.com

WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=
WECHAT_MESSAGE_MODE=plain
WECHAT_ENCODING_AES_KEY=
WECHAT_AUTO_REPLY_TEXT=
WECHAT_ENABLE_PUBLISH=false

# Hybrid mode (set on Vercel only — do NOT set WECHAT_RELAY_URL on SCF):
# Forward all WeChat API calls to Guangzhou SCF fixed egress IP.
# WECHAT_RELAY_URL=https://weixin.koocuu.com
# WECHAT_RELAY_SECRET=   # defaults to MCP_BEARER_TOKEN when omitted

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
